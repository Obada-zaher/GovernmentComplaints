{
  "info": {
    "_postman_id": "d8494854-d3f8-451d-b1e1-a278c94759f8",
    "name": "06 - Notifications",
    "description": "Notification API collection for authenticated users. Use a citizen, employee, or admin bearer token. Notifications are generated by complaint creation, admin assignment, status updates, and the `php artisan complaints:check-sla` command. Database notifications are the reliable channel; Mailtrap email is also sent for assignment, SLA breach, and resolved complaint events.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Notifications",
      "description": "Required token: any authenticated user token. Citizens receive assignment/status/resolved/closed updates for their complaints. Assigned employees receive assignment and SLA breach alerts. Admins receive new complaint, employee escalation, and SLA breach alerts. To generate notifications, log in users, create a complaint, assign it, update status, or run `php artisan complaints:check-sla` for an overdue complaint.",
      "item": [
        {
          "name": "List My Notifications",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{citizen_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notifications",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "notifications"
              ]
            },
            "description": "Lists the authenticated user's notifications newest first. Supports `unread=true`, `type`, and `per_page`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('success key exists', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('success');",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.data && Array.isArray(json.data.notifications) && json.data.notifications.length > 0) {",
                  "    pm.environment.set('notification_id', json.data.notifications[0].id);",
                  "    pm.environment.set('notification_type', json.data.notifications[0].type);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Unread Notifications",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{citizen_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notifications?unread=true",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "notifications"
              ],
              "query": [
                {
                  "key": "unread",
                  "value": "true"
                }
              ]
            },
            "description": "Lists only unread notifications for the authenticated user."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('success key exists', function () {",
                  "    pm.expect(pm.response.json()).to.have.property('success');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Unread Count",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{citizen_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notifications/unread-count",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "notifications",
                "unread-count"
              ]
            },
            "description": "Returns only the current user's unread notification count."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('unread count returns count', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('success', true);",
                  "    pm.expect(json.data).to.have.property('count');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Mark Notification Read",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{citizen_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notifications/{{notification_id}}/read",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "notifications",
                "{{notification_id}}",
                "read"
              ]
            },
            "description": "Marks one owned notification as read. Returns 403 for another user's notification."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('success key exists', function () {",
                  "    pm.expect(pm.response.json()).to.have.property('success');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Mark All Read",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{citizen_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notifications/read-all",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "notifications",
                "read-all"
              ]
            },
            "description": "Marks all unread notifications for the authenticated user as read."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('success key exists', function () {",
                  "    pm.expect(pm.response.json()).to.have.property('success');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Notification",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
