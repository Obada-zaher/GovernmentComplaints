    {
      "name": "Citizen - Offline Sync",
      "description": "Offline sync is for citizen clients that create complaints locally while disconnected. The client must generate and persist a stable client_uuid for each local complaint. Retrying with the same client_uuid returns the same synced complaint and prevents duplicate backend complaints.",
      "item": [
        {
          "name": "Sync Offline Complaint - JSON",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{citizen_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_uuid\": \"{{offline_client_uuid}}\",\n  \"title\": \"Offline complaint from mobile\",\n  \"description\": \"This complaint was created while the user was offline.\",\n  \"department_id\": \"{{department_id}}\",\n  \"category_id\": \"{{category_id}}\",\n  \"priority_id\": \"{{priority_id}}\",\n  \"latitude\": 33.5138,\n  \"longitude\": 36.2765,\n  \"address\": \"Damascus\",\n  \"created_offline_at\": \"2026-07-05T10:00:00Z\",\n  \"source\": \"offline_sync\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/citizen/offline/complaints/sync",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "citizen",
                "offline",
                "complaints",
                "sync"
              ]
            },
            "description": "Purpose: sync one locally-created offline complaint. Required role: citizen. Required token: citizen_token. client_uuid is the idempotency key; mobile/web clients should generate it once locally and reuse it for retries. Expected response: synced complaint and offline_submission tracking record."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('offline_client_uuid', 'offline-' + Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200 or 201', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                  "pm.test('success is true', function () { pm.expect(pm.response.json()).to.have.property('success', true); });",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.complaint) {",
                  "  pm.environment.set('complaint_id', json.data.complaint.id);",
                  "  pm.environment.set('complaint_number', json.data.complaint.complaint_number);",
                  "}",
                  "if (json.data && json.data.offline_submission) { pm.environment.set('offline_submission_id', json.data.offline_submission.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Sync Same Offline Complaint Again - Idempotency Test",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{citizen_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_uuid\": \"{{offline_client_uuid}}\",\n  \"title\": \"Offline complaint from mobile\",\n  \"description\": \"This complaint was created while the user was offline.\",\n  \"department_id\": \"{{department_id}}\",\n  \"category_id\": \"{{category_id}}\",\n  \"priority_id\": \"{{priority_id}}\",\n  \"latitude\": 33.5138,\n  \"longitude\": 36.2765,\n  \"address\": \"Damascus\",\n  \"created_offline_at\": \"2026-07-05T10:00:00Z\",\n  \"source\": \"offline_sync\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/citizen/offline/complaints/sync",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "citizen",
                "offline",
                "complaints",
                "sync"
              ]
            },
            "description": "Purpose: verify retry idempotency with the same client_uuid. Required role: citizen. Required token: citizen_token. Expected response: success true, meta.idempotent true, and the same complaint returned instead of a duplicate."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('success is true', function () { pm.expect(pm.response.json()).to.have.property('success', true); });",
                  "pm.test('idempotent response', function () { pm.expect(pm.response.json().meta).to.have.property('idempotent', true); });"
                ]
              }
            }
          ]
        },
