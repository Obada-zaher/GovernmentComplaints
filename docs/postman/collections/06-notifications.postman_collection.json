    {
      "name": "Device Tokens",
      "description": "Required token: any authenticated user token. Device tokens are normally generated by the frontend/mobile Firebase SDK. Postman uses fake tokens only to test the API contract; real push delivery requires Firebase credentials in .env.",
      "item": [
        {
          "name": "List My Device Tokens",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{citizen_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/device-tokens",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "device-tokens"
              ]
            },
            "description": "Lists only the authenticated user's active device tokens. Required token: citizen_token, employee_token, or admin_token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('success key exists', function () { pm.expect(pm.response.json()).to.have.property('success'); });",
                  "const json = pm.response.json();",
                  "if (json.data && Array.isArray(json.data.device_tokens) && json.data.device_tokens.length > 0) {",
                  "    pm.environment.set('device_token_id', json.data.device_tokens[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Device Token",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('fake_fcm_token', 'fake-fcm-token-' + Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('success key exists', function () { pm.expect(pm.response.json()).to.have.property('success'); });",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) { pm.environment.set('device_token_id', json.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{citizen_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{fake_fcm_token}}\",\n  \"platform\": \"android\",\n  \"device_name\": \"Postman Android Device\",\n  \"app_version\": \"1.0.0\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/device-tokens",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "device-tokens"
              ]
            },
            "description": "Registers or updates one FCM device token for the authenticated user. Postman uses fake_fcm_token for API testing; real tokens come from Firebase SDK in the frontend/mobile app."
          }
        },
        {
          "name": "Delete Device Token",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{citizen_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/device-tokens/{{device_token_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "device-tokens",
                "{{device_token_id}}"
              ]
            },
            "description": "Soft deletes or deactivates one owned device token. Returns 403 for another user's token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('success key exists', function () { pm.expect(pm.response.json()).to.have.property('success'); });"
                ]
              }
            }
          ]
        }
      ]
