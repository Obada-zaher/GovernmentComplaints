    },
    "item": [
        {
            "name": "Auth",
            "description": "Shared authentication endpoints. OTP is never expected in API responses.",
            "item": [
                {
                    "name": "Register",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/auth/register",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "register"
                            ]
                        },
                        "description": "Purpose: Create a citizen account and send an OTP email. OTP is not returned by the API; copy it manually from Mailtrap or the configured email channel.\nRequired role: public\nRequired token: none\nExpected response: standard GCMS API envelope with success, message, data, and meta when present.",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"Citizen User\",\n    \"email\": \"{{citizen_email}}\",\n    \"phone\": \"{{citizen_phone}}\",\n    \"national_id\": \"123456789\",\n    \"password\": \"{{citizen_password}}\",\n    \"password_confirmation\": \"{{citizen_password}}\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        }
                    },
                    "response": [],
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('status code is 200 or 201', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                                    "pm.test('response has success key', function () { var json = pm.response.json(); pm.expect(json).to.have.property('success'); });",
                                    "var json = pm.response.json();",
                                    "function getPath(obj, path) { return path.split('.').reduce(function (current, key) { return current && current[key] !== undefined ? current[key] : undefined; }, obj); }",
                                    "[[\"data.user_id\",\"data.user.id\"]].flat().some(function (path) { var value = getPath(json, path); if (value !== undefined && value !== null && value !== '') { pm.environment.set('citizen_user_id', value); return true; } return false; });"
                                ]
                            }
                        }
                    ]
                },
