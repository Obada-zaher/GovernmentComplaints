                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "verify-otp"
                            ]
                        },
                        "description": "Purpose: Verify the manually copied OTP and receive a Sanctum bearer token.\nRequired role: public\nRequired token: none\nExpected response: standard GCMS API envelope with success, message, data, and meta when present.\nSaved variables: user id and token for the selected role.",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"user_id\": \"{{citizen_user_id}}\",\n    \"otp\": \"{{citizen_otp}}\",\n    \"purpose\": \"login\",\n    \"device_name\": \"Postman\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        }
                    },
                    "response": [],
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('status code is 200 or 201', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                                    "pm.test('response has success key', function () { var json = pm.response.json(); pm.expect(json).to.have.property('success'); });",
                                    "var json = pm.response.json();",
                                    "pm.test('token exists when verification succeeds', function () { pm.expect(json.data).to.have.property('token'); });",
                                    "var json = pm.response.json();",
                                    "function getPath(obj, path) { return path.split('.').reduce(function (current, key) { return current && current[key] !== undefined ? current[key] : undefined; }, obj); }",
                                    "[[\"data.token\"]].flat().some(function (path) { var value = getPath(json, path); if (value !== undefined && value !== null && value !== '') { pm.environment.set('citizen_token', value); return true; } return false; });",
                                    "[[\"data.user.id\",\"data.user_id\"]].flat().some(function (path) { var value = getPath(json, path); if (value !== undefined && value !== null && value !== '') { pm.environment.set('citizen_user_id', value); return true; } return false; });"
                                ]
                            }
                        }
