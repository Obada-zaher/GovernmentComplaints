    {
      "name": "Admin - Classification Rules",
      "item": [
        {
          "name": "List Classification Rules",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{admin_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/classification-rules",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "classification-rules"
              ],
              "query": [
                {
                  "key": "department_id",
                  "value": "{{department_id}}",
                  "disabled": true
                },
                {
                  "key": "category_id",
                  "value": "{{category_id}}",
                  "disabled": true
                },
                {
                  "key": "keyword",
                  "value": "{{classification_keyword}}",
                  "disabled": true
                },
                {
                  "key": "is_active",
                  "value": "true",
                  "disabled": true
                }
              ]
            },
            "description": "Purpose: list keyword/weight classification rules. Required token: admin_token. Required role: admin. Expected behavior: paginated classification_rules array. This is rule-based intelligent classification v1."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('success key exists', function () { pm.expect(pm.response.json()).to.have.property('success'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Classification Rule",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{admin_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"department_id\": \"{{department_id}}\",\n  \"category_id\": \"{{category_id}}\",\n  \"keyword\": \"{{classification_keyword}}\",\n  \"weight\": 5,\n  \"is_active\": true,\n  \"language\": \"en\",\n  \"notes\": \"Street lighting keyword\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/admin/classification-rules",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "classification-rules"
              ]
            },
            "description": "Purpose: create an admin-managed keyword rule. Required token: admin_token. Required role: admin. Expected behavior: returns ClassificationRuleResource and saves classification_rule_id for follow-up requests."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('success key exists', function () { pm.expect(pm.response.json()).to.have.property('success'); });",
                  "const json = pm.response.json(); if (json.data && json.data.id) { pm.environment.set('classification_rule_id', json.data.id); }"
                ]
              }
            }
          ]
        },
