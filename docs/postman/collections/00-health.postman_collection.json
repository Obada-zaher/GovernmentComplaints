{
  "info": {
    "_postman_id": "e8833155-64e7-4740-90d3-b1d57eecca51",
    "name": "00 - Health",
    "description": "Public GCMS API health check under the required /api/v1 prefix. Use this first to verify that Laravel, the database connection, and queue configuration are available.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "API Health",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Purpose: check GCMS API health. Required role: public. Required token: none. Expected response: success=true with app, status, environment, database, queue, time, and version."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('success key exists', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('success', true);",
              "});",
              "pm.test('health data exists', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.data).to.have.property('status', 'ok');",
              "    pm.expect(json.data).to.have.property('database');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
