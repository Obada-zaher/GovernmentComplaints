    {
      "name": "Reports - Snapshots",
      "item": [
        {
          "name": "Create Overview Snapshot",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{admin_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"overview\",\n  \"filters\": {\n    \"date_from\": \"{{report_date_from}}\",\n    \"date_to\": \"{{report_date_to}}\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/reports/snapshots",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "reports",
                "snapshots"
              ]
            },
            "description": "Purpose: store a generated report payload for later review. Required role: admin. Required token: admin_token. Useful filters: any report filter inside filters. Expected response: created snapshot resource with generated report data."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('success key exists', function () { pm.expect(pm.response.json()).to.have.property('success'); });",
                  "pm.test('data exists', function () { pm.expect(pm.response.json()).to.have.property('data'); });",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) { pm.environment.set('snapshot_id', json.data.id); }"
                ]
              }
            }
          ]
        },
