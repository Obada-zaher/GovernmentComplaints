            "description": "Purpose: sync one offline complaint with evidence files. Required role: citizen. Required token: citizen_token. client_uuid prevents duplicate complaints if the upload is retried. Attachments use attachments[] and allowed mimes are jpg, jpeg, png, pdf, doc, and docx up to 5120 KB."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200 or 201', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                  "pm.test('success is true', function () { pm.expect(pm.response.json()).to.have.property('success', true); });"
                ]
              }
            }
          ]
        },
