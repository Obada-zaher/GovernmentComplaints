  "item": [
    {
      "name": "Reports - Overview",
      "item": [
        {
          "name": "Get Overview Report",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{admin_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/reports/overview?date_from={{report_date_from}}&date_to={{report_date_to}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "reports",
                "overview"
              ],
              "query": [
                {
                  "key": "date_from",
                  "value": "{{report_date_from}}",
                  "description": "Optional start date, for example 2026-07-01."
                },
                {
                  "key": "date_to",
                  "value": "{{report_date_to}}",
                  "description": "Optional end date, for example 2026-07-31."
                },
                {
                  "key": "department_id",
                  "value": "{{department_id}}",
                  "disabled": true
                },
                {
                  "key": "priority_id",
                  "value": "{{priority_id}}",
                  "disabled": true
                }
              ]
            },
            "description": "Purpose: overview dashboard metrics including totals, status counts, SLA breach rate, and average response/resolution times. Required role: admin. Required token: admin_token. Useful filters: date_from, date_to, department_id, category_id, priority_id. Expected response: metrics object in data and applied filters in meta."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('success key exists', function () { pm.expect(pm.response.json()).to.have.property('success'); });",
                  "pm.test('data exists', function () { pm.expect(pm.response.json()).to.have.property('data'); });"
                ]
              }
            }
          ]
        }
      ]
    },
