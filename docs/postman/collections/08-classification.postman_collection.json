  "item": [
    {
      "name": "Classification - Preview",
      "item": [
        {
          "name": "Preview Street Lighting Complaint",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{citizen_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Street light is broken\",\n  \"description\": \"The lamp in our street has not worked for three days.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/classification/complaints/preview",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "classification",
                "complaints",
                "preview"
              ]
            },
            "description": "Purpose: preview rule-based classification before creating a complaint. Required token: citizen_token or any authenticated token. Required role: authenticated user. Expected behavior: returns predicted department/category, confidence, matched keywords, alternatives, and method without creating a complaint."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('success key exists', function () { pm.expect(pm.response.json()).to.have.property('success'); });",
                  "pm.test('data.confidence exists', function () { pm.expect(pm.response.json().data).to.have.property('confidence'); });",
                  "const json = pm.response.json(); if (json.data && json.data.confidence !== undefined) { pm.environment.set('classification_confidence', json.data.confidence); }"
                ]
              }
            }
          ]
        },
