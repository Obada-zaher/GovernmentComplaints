    {
      "name": "Notification Delivery Logs - Admin",
      "description": "Required role: admin. Required token: admin_token. Delivery logs show database, email, push, and SMS send/skip/failure outcomes without exposing Firebase tokens or provider secrets.",
      "item": [
        {
          "name": "List Delivery Logs",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{admin_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/notification-delivery-logs?channel=push&status=skipped",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "notification-delivery-logs"
              ],
              "query": [
                {
                  "key": "channel",
                  "value": "push",
                  "description": "Optional: database, email, push, sms"
                },
                {
                  "key": "status",
                  "value": "skipped",
                  "description": "Optional: pending, sent, failed, skipped"
                }
              ]
            },
            "description": "Lists notification delivery logs newest first. Useful filters: user_id, complaint_id, channel, status, type, date_from, date_to, per_page."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('success key exists', function () { pm.expect(pm.response.json()).to.have.property('success'); });",
                  "const json = pm.response.json();",
                  "if (json.data && Array.isArray(json.data.delivery_logs) && json.data.delivery_logs.length > 0) {",
                  "    pm.environment.set('notification_delivery_log_id', json.data.delivery_logs[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Show Delivery Log",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{admin_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/notification-delivery-logs/{{notification_delivery_log_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "notification-delivery-logs",
                "{{notification_delivery_log_id}}"
              ]
            },
            "description": "Shows one delivery log. Required role: admin. Use List Delivery Logs first to save notification_delivery_log_id."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('success key exists', function () { pm.expect(pm.response.json()).to.have.property('success'); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
