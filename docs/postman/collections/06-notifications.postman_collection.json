{
  "info": {
    "_postman_id": "d8494854-d3f8-451d-b1e1-a278c94759f8",
    "name": "06 - Notifications",
    "description": "Notification API collection for authenticated users. Use a citizen, employee, or admin bearer token. Notifications are generated by complaint creation, admin assignment, status updates, and the `php artisan complaints:check-sla` command. Database notifications are the reliable channel; Mailtrap email, Firebase push, and configurable SMS can also be dispatched when preferences and .env settings allow it. Do not commit Firebase or SMS provider secrets.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Notifications",
      "description": "Required token: any authenticated user token. Citizens receive assignment/status/resolved/closed updates for their complaints. Assigned employees receive assignment and SLA breach alerts. Admins receive new complaint, employee escalation, and SLA breach alerts. To generate notifications, log in users, create a complaint, assign it, update status, or run `php artisan complaints:check-sla` for an overdue complaint.",
      "item": [
        {
          "name": "List My Notifications",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{citizen_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notifications",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "notifications"
              ]
            },
            "description": "Lists the authenticated user's notifications newest first. Supports `unread=true`, `type`, and `per_page`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('success key exists', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('success');",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.data && Array.isArray(json.data.notifications) && json.data.notifications.length > 0) {",
                  "    pm.environment.set('notification_id', json.data.notifications[0].id);",
                  "    pm.environment.set('notification_type', json.data.notifications[0].type);",
                  "}"
                ]
              }
            }
          ]
        },
