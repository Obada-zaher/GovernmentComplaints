              ]
            },
            "description": "Deletes one owned notification. Returns 403 for another user's notification."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('success key exists', function () {",
                  "    pm.expect(pm.response.json()).to.have.property('success');",
                  "});"
                ]
