    "item":  [
                 {
                     "name":  "List My Complaints",
                     "request":  {
                                     "method":  "GET",
                                     "header":  [
                                                    {
                                                        "key":  "Accept",
                                                        "value":  "application/json"
                                                    }
                                                ],
                                     "url":  {
                                                 "raw":  "{{base_url}}/citizen/complaints",
                                                 "host":  [
                                                              "{{base_url}}"
                                                          ],
                                                 "path":  [
                                                              "citizen",
                                                              "complaints"
                                                          ]
                                             },
                                     "description":  "Purpose: list only authenticated citizen complaints. Required token: citizen_token. Supports status, department_id, category_id, priority_id, date_from, date_to, search, per_page.",
                                     "auth":  {
                                                  "type":  "bearer",
                                                  "bearer":  [
                                                                 {
                                                                     "key":  "token",
                                                                     "value":  "{{citizen_token}}",
                                                                     "type":  "string"
                                                                 }
                                                             ]
                                              }
                                 },
                     "response":  [

                                  ],
                     "event":  [
                                   {
                                       "listen":  "test",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "pm.test(\u0027success key exists\u0027, function () { const json = pm.response.json(); pm.expect(json).to.have.property(\u0027success\u0027); });"
                                                               ]
                                                  }
                                   }
                               ]
                 },
                 {
                     "name":  "Create Complaint - JSON",
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Accept",
                                                        "value":  "application/json"
                                                    },
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    }
                                                ],
                                     "url":  {
                                                 "raw":  "{{base_url}}/citizen/complaints",
                                                 "host":  [
                                                              "{{base_url}}"
                                                          ],
                                                 "path":  [
                                                              "citizen",
                                                              "complaints"
                                                          ]
                                             },
                                     "description":  "Purpose: create complaint from JSON. Required token: citizen_token. Saves complaint_id and complaint_number. Employee processing and admin assignment are not part of this endpoint.",
                                     "auth":  {
                                                  "type":  "bearer",
                                                  "bearer":  [
                                                                 {
                                                                     "key":  "token",
                                                                     "value":  "{{citizen_token}}",
                                                                     "type":  "string"
                                                                 }
                                                             ]
                                              },
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"title\": \"Street light is broken\",\n  \"description\": \"The street light near my house has been broken for three days.\",\n  \"department_id\": \"{{department_id}}\",\n  \"category_id\": \"{{category_id}}\",\n  \"priority_id\": \"{{priority_id}}\",\n  \"latitude\": 33.5138,\n  \"longitude\": 36.2765,\n  \"address\": \"Damascus\",\n  \"source\": \"web\"\n}",
                                                  "options":  {
                                                                  "raw":  {
                                                                              "language":  "json"
                                                                          }
                                                              }
                                              }
                                 },
                     "response":  [

                                  ],
                     "event":  [
                                   {
                                       "listen":  "test",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "pm.test(\u0027success key exists\u0027, function () { const json = pm.response.json(); pm.expect(json).to.have.property(\u0027success\u0027); });",
                                                                   "const json = pm.response.json(); if (json.data) { pm.environment.set(\u0027complaint_id\u0027, json.data.id); pm.environment.set(\u0027complaint_number\u0027, json.data.complaint_number); }"
                                                               ]
                                                  }
                                   }
                               ]
                 },
